FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
WORKDIR /app
EXPOSE 8080

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY ["Services/VoterService/VoterService.csproj", "Services/VoterService/"]
RUN dotnet restore "Services/VoterService/VoterService.csproj"

COPY . .
WORKDIR "/src/Services/VoterService"
RUN dotnet build "VoterService.csproj" -c Release -o /app/build

FROM build AS publish
RUN dotnet publish "VoterService.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "VoterService.dll"]