{
  "Authentication": {
    "Authority": "http://keycloak:8080/realms/votoseguro"
  },
  "ReverseProxy": {
    "Routes": {
      "voter-route": {
        "ClusterId": "voter-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/votantes/{**catch-all}"
        }
      },
      "referendum-route": {
        "ClusterId": "referendum-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/referendums/{**catch-all}"
        }
      },
      "vote-route": {
        "ClusterId": "vote-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/votes/{**catch-all}"
        }
      },
      "result-route": {
        "ClusterId": "result-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/results/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "voter-cluster": {
        "Destinations": {
          "voter-service": {
            "Address": "http://voterservice:8080/"
          }
        }
      },
      "referendum-cluster": {
        "Destinations": {
          "referendum-service": {
            "Address": "http://referendumservice:8080/"
          }
        }
      },
      "vote-cluster": {
        "Destinations": {
          "vote-service": {
            "Address": "http://voteservice:8080/"
          }
        }
      },
      "result-cluster": {
        "Destinations": {
          "result-service": {
            "Address": "http://resultservice:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}