{
  "Authentication": {
    "MetadataAddress": "http://keycloak:8080/realms/votoseguro/.well-known/openid-configuration",
    "ValidIssuer": "https://mocker-evil-stapling.ngrok-free.dev/realms/votoseguro"
  },
  "ReverseProxy": {
    "Routes": {
      "voter-route": {
        "ClusterId": "voter-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/votantes/{**catch-all}"
        }
      },
      "referendum-route": {
        "ClusterId": "referendum-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/referendums/{**catch-all}"
        }
      },
      "vote-route": {
        "ClusterId": "vote-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/votes/{**catch-all}"
        }
      },
      "result-route": {
        "ClusterId": "result-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/results/{**catch-all}"
        }
      },
      "auth-register-admin-route": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/auth/register-admin",
          "Methods": [
            "POST"
          ]
        }
      },
      "auth-register-voter-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/auth/register-voter",
          "Methods": [
            "POST"
          ]
        }
      },
      "auth-delete-voter-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/api/auth/voters/{idVotante}",
          "Methods": [
            "DELETE"
          ]
        }
      },
      "keycloak-realms-route": {
        "ClusterId": "keycloak-cluster",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/realms/{**catch-all}"
        }
      },
      "keycloak-resources-route": {
        "ClusterId": "keycloak-cluster",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/resources/{**catch-all}"
        }
      },
      "keycloak-admin-route": {
        "ClusterId": "keycloak-cluster",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/admin/{**catch-all}"
        }
      },
      "keycloak-js-route": {
        "ClusterId": "keycloak-cluster",
        "CorsPolicy": "FrontendCors",
        "Match": {
          "Path": "/js/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "voter-cluster": {
        "Destinations": {
          "voter-service": {
            "Address": "http://voterservice:8080/"
          }
        }
      },
      "referendum-cluster": {
        "Destinations": {
          "referendum-service": {
            "Address": "http://referendumservice:8080/"
          }
        }
      },
      "vote-cluster": {
        "Destinations": {
          "vote-service": {
            "Address": "http://voteservice:8080/"
          }
        }
      },
      "result-cluster": {
        "Destinations": {
          "result-service": {
            "Address": "http://resultservice:8080/"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://authservice:8080/"
          }
        }
      },
      "keycloak-cluster": {
        "Destinations": {
          "keycloak-service": {
            "Address": "http://keycloak:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}